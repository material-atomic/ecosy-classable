{
  "name": "@ecosy/classable",
  "version": "0.2.0",
  "description": "A type-safe, composable class name builder with conditional merging, variant support, and zero runtime dependencies",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "agents"
  ],
  "agents": {
    "prompts": {
      "classable": "$this://agents/PROMPT.md"
    },
    "rules": {
      "classable": "$this://agents/RULES.md"
    },
    "skills": {
      "$overview": "$this://agents/skills/index.md",
      "classable-injectable": "$this://agents/skills/classable-injectable/SKILL.md",
      "classable-teleportability": "$this://agents/skills/classable-teleportability/SKILL.md",
      "classable-inject": "$this://agents/skills/classable-inject/SKILL.md",
      "classable-executable": "$this://agents/skills/classable-executable/SKILL.md",
      "classable-lifecycle": "$this://agents/skills/classable-lifecycle/SKILL.md",
      "classable-global-transient": "$this://agents/skills/classable-global-transient/SKILL.md",
      "classable-placeholder": "$this://agents/skills/classable-placeholder/SKILL.md",
      "classable-project-example": "$this://agents/skills/classable-project-example/SKILL.md"
    },
    "workflows": [
      "prompts.classable",
      "rules.classable",
      "skills.classable-injectable",
      "skills.classable-teleportability",
      "skills.classable-inject",
      "skills.classable-executable",
      "skills.classable-lifecycle",
      "skills.classable-global-transient",
      "skills.classable-placeholder",
      "skills.classable-project-example"
    ],
    "examples": {
      "project": {
        "repository": "github.com:material-atomic/ecosy-markdoc",
        "url": "https://markdoc.ecosy.io"
      }
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "eslint src/ && rollup -c",
    "prepublishOnly": "yarn clean && yarn build",
    "dev": "rollup -c --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/material-atomic/ecosy-classable.git"
  },
  "keywords": [
    "ecosy",
    "classable",
    "classnames",
    "clsx",
    "css",
    "variant",
    "typescript"
  ],
  "author": "material-atomic",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "glob": "^13.0.6",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.1",
    "typescript": "^5.9.3"
  }
}
