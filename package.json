{
  "name": "@ecosy/classable",
  "version": "0.2.0",
  "description": "A type-safe, composable class name builder with conditional merging, variant support, and zero runtime dependencies",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "agents"
  ],
  "agents": {
    "prompts": {
      "classable": "$this://agents/PROMPT.md"
    },
    "rules": {
      "classable": "$this://agents/RULES.md"
    },
    "skills": {
      "$overview": "$this://agents/skills/index.md",
      "classable-injectable": "$this://agents/skills/classable-injectable/SKILL.md",
      "classable-teleportability": "$this://agents/skills/classable-teleportability/SKILL.md",
      "classable-inject": "$this://agents/skills/classable-inject/SKILL.md",
      "classable-executable": "$this://agents/skills/classable-executable/SKILL.md",
      "classable-lifecycle": "$this://agents/skills/classable-lifecycle/SKILL.md",
      "classable-global-transient": "$this://agents/skills/classable-global-transient/SKILL.md",
      "classable-placeholder": "$this://agents/skills/classable-placeholder/SKILL.md",
      "classable-project-example": "$this://agents/skills/classable-project-example/SKILL.md"
    },
    "workflows": [
      "prompts.classable",
      "rules.classable",
      "skills.classable-injectable",
      "skills.classable-teleportability",
      "skills.classable-inject",
      "skills.classable-executable",
      "skills.classable-lifecycle",
      "skills.classable-global-transient",
      "skills.classable-placeholder",
      "skills.classable-project-example"
    ],
    "examples": {
      "project": {
        "repository": "github.com:material-atomic/ecosy-markdoc",
        "url": "https://markdoc.ecosy.io"
      }
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./classable": {
      "types": "./dist/classable.d.ts",
      "import": "./dist/classable.mjs",
      "require": "./dist/classable.js"
    },
    "./injectable": {
      "types": "./dist/injectable.d.ts",
      "import": "./dist/injectable.mjs",
      "require": "./dist/injectable.js"
    },
    "./inject": {
      "types": "./dist/inject.d.ts",
      "import": "./dist/inject.mjs",
      "require": "./dist/inject.js"
    },
    "./executable": {
      "types": "./dist/executable.d.ts",
      "import": "./dist/executable.mjs",
      "require": "./dist/executable.js"
    },
    "./executor": {
      "types": "./dist/executor.d.ts",
      "import": "./dist/executor.mjs",
      "require": "./dist/executor.js"
    },
    "./teleportability": {
      "types": "./dist/teleportability.d.ts",
      "import": "./dist/teleportability.mjs",
      "require": "./dist/teleportability.js"
    },
    "./teleportable": {
      "types": "./dist/teleportable.d.ts",
      "import": "./dist/teleportable.mjs",
      "require": "./dist/teleportable.js"
    },
    "./global": {
      "types": "./dist/global.d.ts",
      "import": "./dist/global.mjs",
      "require": "./dist/global.js"
    },
    "./transient": {
      "types": "./dist/transient.d.ts",
      "import": "./dist/transient.mjs",
      "require": "./dist/transient.js"
    },
    "./lifecycle": {
      "types": "./dist/lifecycle.d.ts",
      "import": "./dist/lifecycle.mjs",
      "require": "./dist/lifecycle.js"
    },
    "./placeholder": {
      "types": "./dist/placeholder.d.ts",
      "import": "./dist/placeholder.mjs",
      "require": "./dist/placeholder.js"
    },
    "./anchorable": {
      "types": "./dist/anchorable.d.ts",
      "import": "./dist/anchorable.mjs",
      "require": "./dist/anchorable.js"
    },
    "./anchoribility": {
      "types": "./dist/anchoribility.d.ts",
      "import": "./dist/anchoribility.mjs",
      "require": "./dist/anchoribility.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.js"
    }
  },
  "typesVersions": {
    "*": {
      "classable": ["./dist/classable.d.ts"],
      "injectable": ["./dist/injectable.d.ts"],
      "inject": ["./dist/inject.d.ts"],
      "executable": ["./dist/executable.d.ts"],
      "executor": ["./dist/executor.d.ts"],
      "teleportability": ["./dist/teleportability.d.ts"],
      "teleportable": ["./dist/teleportable.d.ts"],
      "global": ["./dist/global.d.ts"],
      "transient": ["./dist/transient.d.ts"],
      "lifecycle": ["./dist/lifecycle.d.ts"],
      "placeholder": ["./dist/placeholder.d.ts"],
      "anchorable": ["./dist/anchorable.d.ts"],
      "anchoribility": ["./dist/anchoribility.d.ts"],
      "types": ["./dist/types.d.ts"]
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "eslint src/ && rollup -c",
    "prepublishOnly": "yarn clean && yarn build",
    "dev": "rollup -c --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/material-atomic/ecosy-classable.git"
  },
  "keywords": [
    "ecosy",
    "classable",
    "classnames",
    "clsx",
    "css",
    "variant",
    "typescript"
  ],
  "author": "material-atomic",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "glob": "^13.0.6",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
